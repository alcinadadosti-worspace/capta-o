# Copie este arquivo para ".env" (local) e preencha com seus valores reais.
# NUNCA suba o arquivo .env para o GitHub — ele contém segredos.
# No Render, esses valores vão em "Environment".

# String de conexão do banco Neon (copie do painel do Neon)
DATABASE_URL=postgresql://usuario:senha@host.neon.tech/neondb?sslmode=require

# Token do bot do Slack (começa com "xoxb-"). Cole aqui o token real do seu bot.
SLACK_BOT_TOKEN=COLE_SEU_TOKEN_DO_SLACK_AQUI

# Destinos do Slack por região (OPCIONAIS).
# Os IDs já estão embutidos no server.js como padrão — só preencha aqui/no
# Render se um dia quiser TROCAR para onde os avisos vão, sem mexer no código.
#   Região A: Palmeira dos Índios, Igaci, Major Isidoro, Quebrangulo,
#             Estrela de Alagoas, Minador do Negrão, Cacimbinhas
#   Região B: Penedo, Igreja Nova, São Brás, Porto Real do Colégio,
#             São Sebastião, Junqueiro, Teotônio Vilela, Piaçabuçu,
#             Feliz Deserto, Coruripe
#   Padrão:   qualquer outra cidade (e cidades de mesmo nome fora de AL)
# SLACK_ID_REGIAO_A=U0AHTBS64KH
# SLACK_ID_REGIAO_B=U087HG1B4DB
# SLACK_ID_PADRAO=U07LP4JSN9K

# Porta local (o Render define automaticamente; deixe assim para testes locais)
PORT=3000
